# Base site URL used for metadata, RSS feeds, and OG tags
NEXT_PUBLIC_BASE_URL=https://www.design-prism.com

# Override the default GA4 property (falls back to G-P9VY77PRC0 if empty)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional custom endpoint for the scholarship form (defaults to Formspree)
NEXT_PUBLIC_SCHOLARSHIP_FORM_ENDPOINT=https://formspree.io/f/mwpwwjek
# Optional custom endpoint for the free AEO assessment form (defaults to Formspree)
NEXT_PUBLIC_AEO_FORM_ENDPOINT=https://formspree.io/f/xldarokj
# Optional custom endpoint for the one-time website build estimator form (defaults to Formspree)
NEXT_PUBLIC_WEBSITE_BUILD_FORM_ENDPOINT=https://formspree.io/f/xpqebnbz
# Optional custom endpoint for the main Prism application form (defaults to Formspree)
NEXT_PUBLIC_APPLY_FORM_ENDPOINT=https://formspree.io/f/mreroojo
# Preferred endpoint for the Prism dashboard intake API. When set, /apply creates
# a client dashboard immediately and the dashboard app may mirror to Formspree.
NEXT_PUBLIC_DASHBOARD_INTAKE_ENDPOINT=
# Backward-compatible fallback name for older get-started form configs
NEXT_PUBLIC_GET_STARTED_FORM_ENDPOINT=
# Optional public override for the stock ElevenLabs widget on eligible routes
# (`/pricing` and `/contact` on non-mobile viewports).
# Falls back to Prism Sales (agent_4701kkcyc4efefkv5x4awhysjyrh) when unset.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Optional comma-separated host allowlist for clickable markdown links inside ElevenLabs widgets.
# Defaults include Prism pages plus trusted booking hosts like calendar.notion.so and cal.com.
NEXT_PUBLIC_ELEVENLABS_MARKDOWN_LINK_ALLOWED_HOSTS=
# Optional public kill switch for debugging or deterministic visual builds.
# Leave unset in normal development so the stock ElevenLabs widgets mount as expected.
NEXT_PUBLIC_ELEVENLABS_WIDGET_DISABLED=

# Prism Library social API credentials
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
TIKTOK_ACCESS_TOKEN=

# Used by deployment verification scripts
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=
