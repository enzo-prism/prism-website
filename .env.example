# Base site URL used for metadata, RSS feeds, and OG tags
NEXT_PUBLIC_BASE_URL=https://www.design-prism.com

# Override the default GA4 property (falls back to G-P9VY77PRC0 if empty)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional custom endpoint for the scholarship form (defaults to Formspree)
NEXT_PUBLIC_SCHOLARSHIP_FORM_ENDPOINT=https://formspree.io/f/mwpwwjek
# Optional custom endpoint for the free AEO assessment form (defaults to Formspree)
NEXT_PUBLIC_AEO_FORM_ENDPOINT=https://formspree.io/f/xldarokj
# Optional public override for the homepage ElevenLabs hero agent.
# Falls back to Prism Sales (agent_4701kkcyc4efefkv5x4awhysjyrh) when unset.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Optional public booking URL for legacy/custom ElevenLabs integrations.
# The current site uses the stock widget, so this only matters if you revive custom client-tool flows.
NEXT_PUBLIC_ELEVENLABS_BOOKING_URL=
# Optional comma-separated host allowlist for markdown links rendered by the stock ElevenLabs widget.
# Defaults include Prism pages plus trusted booking hosts like calendar.notion.so and cal.com.
NEXT_PUBLIC_ELEVENLABS_MARKDOWN_LINK_ALLOWED_HOSTS=

# Supabase credentials for storing Prism leads (required for /api/prism-leads)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key for email notifications (lib/email.ts)
RESEND_API_KEY=

# Prism Library social API credentials
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
TIKTOK_ACCESS_TOKEN=

# Used by deployment verification scripts
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=

# Sales chat deterministic engine configuration
SALES_CHAT_ENABLED=
SALES_CHAT_BOOKING_URL=
SALES_CHAT_WEBSITE_OVERHAUL_CHECKOUT_URL=
SALES_CHAT_GROWTH_PARTNERSHIP_SIGNUP_URL=
# Preferred explicit secret for signing sales-chat state tokens.
# If unset, runtime falls back to another server secret, but setting this directly is recommended.
SALES_CHAT_STATE_SECRET=
# Supports Formspree endpoint (example: https://formspree.io/f/mvzbnydz) or custom webhook URL.
SALES_CHAT_LEADS_WEBHOOK_URL=
# Required for non-Formspree webhooks; optional when using Formspree.
SALES_CHAT_LEADS_WEBHOOK_SECRET=
# Optional: master switch for AI response orchestration upgrades on /api/chat.
SALES_CHAT_AI_FALLBACK_ENABLED=false
# Optional: AI response mode (`off`, `long_tail`, `broad`). If unset, runtime defaults to `broad` when AI orchestration is enabled.
SALES_CHAT_AI_RESPONSE_MODE=broad
# Optional canary controls for AI orchestration rollout.
SALES_CHAT_AI_ORCHESTRATION_ENABLED=true
SALES_CHAT_AI_ORCHESTRATION_PERCENT=100
SALES_CHAT_AI_ORCHESTRATION_COHORT=default
# Optional gateway vars; required only when SALES_CHAT_AI_FALLBACK_ENABLED=true.
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=
# Optional timeout (ms) per orchestrated generation request.
AI_GATEWAY_TIMEOUT_MS=7000
# Optional: comma-separated fallback models (for example: openai/gpt-5,openai/gpt-4.1-mini).
AI_GATEWAY_FALLBACK_MODELS=
# Optional: comma-separated provider preference order (for example: openai,anthropic).
AI_GATEWAY_PROVIDER_ORDER=
# Optional: fast model routing for short/simple turns.
AI_GATEWAY_FAST_MODEL=
AI_GATEWAY_FAST_MODEL_MAX_CHARS=190
AI_GATEWAY_FORCE_FAST_MODEL=false
# Optional sales-chat telemetry webhook.
SALES_CHAT_EVENTS_WEBHOOK_URL=
SALES_CHAT_EVENTS_WEBHOOK_SECRET=
